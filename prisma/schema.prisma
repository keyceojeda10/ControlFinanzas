// Control Finanzas - Schema de Prisma
// SaaS multi-tenant para gestión de cartera de crédito informal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Plan {
  test
  basic
  growth
  standard
  professional
}

enum Rol {
  owner
  cobrador
  superadmin
}

enum EstadoCliente {
  activo
  mora
  cancelado
  inactivo
  eliminado
}

enum EstadoPrestamo {
  activo
  completado
  cancelado
}

enum TipoPago {
  completo
  parcial
  capital
  recargo
  descuento
}

enum EstadoSuscripcion {
  activa
  vencida
  cancelada
}

enum TipoSuscripcion {
  pago_unico
  recurrente
}

// ─── MODELOS ─────────────────────────────────────────────

model Organization {
  id              String         @id @default(cuid())
  nombre          String
  plan            Plan           @default(basic)
  telefono        String?
  ciudad          String?
  activo          Boolean        @default(true)
  codigoReferido  String?        @unique
  referidoPorId   String?
  descuento       Int            @default(0)
  cobradoresExtra Int            @default(0)
  rutasExtra      Int            @default(0)
  estadoContacto  EstadoContacto @default(nuevo)
  fuenteRegistro  String?
  planOriginal    Plan?
  planDemoHasta   DateTime?
  onboardingStep  Int            @default(0)
  trialReminderSent Boolean      @default(false)
  createdAt       DateTime       @default(now())

  referidoPor      Organization?     @relation("Referidos", fields: [referidoPorId], references: [id])
  referidos        Organization[]    @relation("Referidos")
  users            User[]
  rutas            Ruta[]
  clientes         Cliente[]
  prestamos        Prestamo[]
  pagos            Pago[]
  cierresCaja      CierreCaja[]
  suscripciones    Suscripcion[]
  adminLogs        AdminLog[]
  gastosMenores    GastoMenor[]
  tickets          TicketSoporte[]
  notasSeguimiento NotaSeguimiento[]
  leads            Lead[]
  capital          Capital?
  movimientosCapital MovimientoCapital[]
  actividadLogs    ActividadLog[]

  @@index([createdAt])
}

model User {
  id                      String    @id @default(cuid())
  organizationId          String?
  nombre                  String
  email                   String    @unique
  telefono                String?
  password                String
  rol                     Rol
  activo                  Boolean   @default(true)
  emailVerificado         Boolean   @default(false)
  tokenVerificacion       String?   @unique
  tokenExpira             DateTime?
  onboardingCompletado    Boolean   @default(false)
  terminosAceptados       Boolean   @default(false)
  fechaAceptacionTerminos DateTime?
  puedeCrearPrestamos     Boolean   @default(false)
  puedeCrearClientes      Boolean   @default(false)
  puedeEditarClientes     Boolean   @default(false)
  createdAt               DateTime  @default(now())

  organization   Organization?     @relation(fields: [organizationId], references: [id])
  rutas          Ruta[]            @relation("CobradorRuta")
  pagos          Pago[]
  cierresCaja    CierreCaja[]
  adminLogs      AdminLog[]        @relation("AdminLogs")
  gastosMenores  GastoMenor[]      @relation("CobradorGastos")
  tickets        TicketSoporte[]
  mensajesTicket MensajeTicket[]
  notasAdmin     NotaSeguimiento[] @relation("NotasAdmin")
  actividadLogs      ActividadLog[]
  pushSubscriptions  PushSubscription[]

  @@index([organizationId])
}

model Ruta {
  id             String   @id @default(cuid())
  organizationId String
  cobradorId     String?
  nombre         String
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  cobrador     User?        @relation("CobradorRuta", fields: [cobradorId], references: [id])
  clientes     Cliente[]

  @@index([organizationId])
}

model Cliente {
  id             String        @id @default(cuid())
  organizationId String
  rutaId         String?
  ordenRuta      Int?
  nombre         String
  cedula         String
  telefono       String?
  direccion      String?
  referencia     String?       @db.VarChar(100)
  notas          String?       @db.Text
  fotoUrl        String?
  latitud        Float?
  longitud       Float?
  estado         EstadoCliente @default(activo)
  eliminadoEn    DateTime?
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  ruta         Ruta?        @relation(fields: [rutaId], references: [id])
  prestamos    Prestamo[]

  @@unique([organizationId, cedula])
  @@index([organizationId])
  @@index([cedula])
  @@index([estado])
}

model Prestamo {
  id             String         @id @default(cuid())
  clienteId      String
  organizationId String
  montoPrestado  Float
  tasaInteres    Float
  totalAPagar    Float
  cuotaDiaria    Float
  frecuencia     String         @default("diario")
  fechaInicio    DateTime
  fechaFin       DateTime
  diasPlazo      Int
  estado         EstadoPrestamo @default(activo)
  createdAt      DateTime       @default(now())

  cliente      Cliente      @relation(fields: [clienteId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  pagos        Pago[]

  @@index([organizationId])
  @@index([clienteId])
}

model Pago {
  id             String   @id @default(cuid())
  prestamoId     String
  organizationId String
  cobradorId     String?
  montoPagado    Float
  fechaPago      DateTime @default(now())
  tipo           TipoPago
  metodoPago     String?  // 'efectivo' | 'transferencia'
  plataforma     String?  // Nequi, Daviplata, Bancolombia, etc. (texto libre)
  nota           String?
  createdAt      DateTime @default(now())

  prestamo     Prestamo     @relation(fields: [prestamoId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  cobrador     User?        @relation(fields: [cobradorId], references: [id])

  @@index([organizationId])
  @@index([prestamoId])
}

model CierreCaja {
  id             String   @id @default(cuid())
  organizationId String
  cobradorId     String
  fecha          DateTime
  totalEsperado  Float
  totalRecogido  Float
  totalGastos    Float    @default(0)
  diferencia     Float
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  cobrador     User         @relation(fields: [cobradorId], references: [id])

  @@index([organizationId])
  @@index([organizationId, fecha])
  @@index([cobradorId, fecha])
}

model Suscripcion {
  id               String            @id @default(cuid())
  organizationId   String
  plan             Plan
  estado           EstadoSuscripcion @default(activa)
  fechaInicio      DateTime
  fechaVencimiento DateTime
  montoCOP         Int
  mercadopagoId    String?

  // Suscripción recurrente (MercadoPago PreApproval)
  tipo              TipoSuscripcion  @default(pago_unico)
  preapprovalId     String?          @unique
  mpStatus          String?          // pending, authorized, paused, cancelled
  frecuenciaMeses   Int              @default(1)
  ultimoCobroAt     DateTime?
  proximoCobroAt    DateTime?
  canceladaAt       DateTime?
  motivoCancelacion String?

  createdAt        DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([tipo, estado])
}

model GastoMenor {
  id             String      @id @default(cuid())
  description    String
  monto          Float
  fecha          DateTime    @default(now())
  estado         GastoEstado @default(pendiente)
  cobradorId     String?
  organizationId String

  cobrador     User?        @relation("CobradorGastos", fields: [cobradorId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([cobradorId])
  @@index([organizationId, fecha])
}

enum GastoEstado {
  pendiente
  aprobado
  rechazado
}

enum TipoMovimiento {
  capital_inicial
  inyeccion
  retiro
  desembolso
  recaudo
  gasto
  ajuste
}

model Capital {
  id             String   @id @default(cuid())
  organizationId String   @unique
  saldo          Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  movimientos    MovimientoCapital[]
}

model MovimientoCapital {
  id             String          @id @default(cuid())
  capitalId      String
  organizationId String
  tipo           TipoMovimiento
  monto          Float
  saldoAnterior  Float
  saldoNuevo     Float
  descripcion    String?
  referenciaId   String?
  referenciaTipo String?
  creadoPorId    String?
  createdAt      DateTime        @default(now())

  capital        Capital          @relation(fields: [capitalId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([capitalId])
  @@index([referenciaId])
}

enum EstadoContacto {
  nuevo
  contactado
  interesado
  activo_pagado
  perdido
}

model AdminLog {
  id             String   @id @default(cuid())
  adminId        String
  accion         String
  organizacionId String?
  detalle        String?
  createdAt      DateTime @default(now())

  admin        User          @relation("AdminLogs", fields: [adminId], references: [id])
  organizacion Organization? @relation(fields: [organizacionId], references: [id])

  @@index([adminId])
}

// ─── ACTIVIDAD / AUDIT LOG ─────────────────────────────────

model ActividadLog {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String
  accion          String         // crear_prestamo, registrar_pago, crear_cliente, etc.
  entidadTipo     String         // prestamo, pago, cliente, ruta, gasto, caja, capital
  entidadId       String?
  detalle         String?  @db.Text
  ip              String?
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  user            User         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
}

// ─── EVENTOS / ANALYTICS ───────────────────────────────

model Evento {
  id              String   @id @default(cuid())
  organizationId  String?
  userId          String?
  evento          String         // page_view, feature_click, api_call
  pagina          String?        // /dashboard, /prestamos, etc.
  metadata        String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([organizationId, createdAt])
  @@index([evento, createdAt])
}

// ─── PUSH NOTIFICATIONS ────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── SOPORTE ─────────────────────────────────────────────

enum TipoTicket {
  bug
  pregunta
  solicitud
  problema_pago
  otro
}

enum EstadoTicket {
  abierto
  en_progreso
  resuelto
  cerrado
}

model TicketSoporte {
  id               String       @id @default(cuid())
  organizationId   String
  userId           String
  tipo             TipoTicket
  asunto           String
  descripcion      String       @db.Text
  estado           EstadoTicket @default(abierto)
  solicitaContacto Boolean      @default(false)
  telefonoContacto String?
  contactoAtendido Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
  mensajes     MensajeTicket[]

  @@index([organizationId])
  @@index([estado])
  @@index([userId])
}

model MensajeTicket {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  contenido String   @db.Text
  imagenUrl String?
  esAdmin   Boolean  @default(false)
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket TicketSoporte @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

// ─── CRM ─────────────────────────────────────────────────

model NotaSeguimiento {
  id             String          @id @default(cuid())
  organizationId String
  adminId        String
  contenido      String          @db.Text
  estadoContacto EstadoContacto?
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admin        User         @relation("NotasAdmin", fields: [adminId], references: [id])

  @@index([organizationId])
}

// ─── LEADS ──────────────────────────────────────────────

model Lead {
  id               String        @id @default(cuid())
  nombre           String
  telefono         String
  cantClientes     String?
  anuncioId        String?
  estado           String        @default("nuevo")
  notas            String?       @db.Text
  organizationId   String?
  mensajesEnviados      String?       @db.Text
  ultimoRecordatorio    DateTime?
  recordatoriosEnviados Int           @default(0)
  telegramMessageId     Int?
  esPrestamista         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([createdAt])
  @@index([estado])
  @@index([telefono])
}
